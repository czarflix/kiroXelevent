{
  "name": "@voicegauntlet/mcp",
  "version": "0.1.0",
  "description": "Local Kiro MCP server for VoiceGauntlet. Private to this repo; run with pnpm mcp.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@voicegauntlet/core": "workspace:*",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
